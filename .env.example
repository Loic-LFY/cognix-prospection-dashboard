# ============================================================
# Cognix Prospection Dashboard — Variables d'environnement
# ============================================================
#
# ARCHITECTURE :
#   .env.local (sur le VPS, à la racine du projet) → NE CONTIENT QUE :
#       DATABASE_URL=/data/leads.db
#
#   Toutes les autres variables sont injectées au runtime via
#   le docker-compose.yml (section environment:), PAS via .env.local.
#   Elles sont lues exclusivement via process.env côté serveur,
#   sans préfixe NEXT_PUBLIC_.
# ============================================================

# ── .env.local (VPS uniquement) ─────────────────────────────
DATABASE_URL=/data/leads.db

# ── docker-compose environment (runtime) ────────────────────

# Authentification dashboard (page de login navigateur)
DASHBOARD_PASSWORD=changeme-mot-de-passe-fort

# Authentification API machine-to-machine (Hermes → dashboard)
API_KEY=changeme-api-key

# PhantomBuster (LinkedIn outreach)
# Si présente → mode RÉEL activé automatiquement
# Si absente  → mode SIMULATION
PHANTOMBUSTER_API_KEY=
PHANTOMBUSTER_AGENT_ID_SEARCH=       # phantom "LinkedIn Profile URL Finder" (recherche profil depuis nom+société)
PHANTOMBUSTER_AGENT_ID_CONNECTION=   # phantom "LinkedIn Auto Connect"        (demandes de mise en relation)
PHANTOMBUSTER_AGENT_ID_MESSAGE=      # phantom "LinkedIn Message Sender"      (messages aux connexions)

# Resend (canal email — optionnel)
# Expéditeur : loic.fretay@cognix-systems.com
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=               # secret HMAC pour les webhooks Resend
RESEND_TRACKING_ENABLED=false        # true seulement après config DNS cognix-systems.com

# Divers
PORT=3000
CRM_URL=
CALENDLY_URL=https://calendly.com/loic-fretay-cognix-systems/45min
