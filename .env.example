# Cognix Prospection Dashboard — Variables d'environnement
# Copier vers ~/openclaw/.env et renseigner les valeurs

# Dashboard
DASHBOARD_API_KEY=your-api-key-here
DASHBOARD_API_URL=https://cognix.7solutionsweb.com

# Base de données SQLite
DATABASE_URL=/home/node/.openclaw/workspace/state/cognix/leads.db

# PhantomBuster (LinkedIn outreach)
PHANTOMBUSTER_API_KEY=
PHANTOMBUSTER_AGENT_ID_CONNECTION=   # ID phantom "LinkedIn Network Booster"
PHANTOMBUSTER_AGENT_ID_MESSAGE=      # ID phantom "LinkedIn Message Sender"

# Resend (canal email, optionnel)
# Expéditeur : loic.fretay@cognix-systems.com
# Clé à générer sur https://resend.com/api-keys
RESEND_API_KEY=

# Tracking ouverture email (Resend) — désactivé par défaut
# Activer uniquement après configuration DNS côté cognix-systems.com
# RESEND_TRACKING_ENABLED=false

# CRM externe (optionnel)
CRM_URL=
CALENDLY_URL=
