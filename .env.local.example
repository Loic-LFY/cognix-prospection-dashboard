# Path to your SQLite database
# Default: /home/node/.openclaw/workspace/state/cognix/leads.db
DATABASE_URL=/home/node/.openclaw/workspace/state/cognix/leads.db

# API key for authenticating API calls (via x-api-key header)
# Leave empty to disable auth (dev mode)
API_KEY=your-secret-key-here

# Next.js server port
PORT=3000
